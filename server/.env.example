# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# 1. Create a cluster (free tier)
# 2. Create a database user
# 3. Network Access → Allow IP from anywhere (0.0.0.0/0)
# 4. Connect → Connect your application → Copy the connection string

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/school-portal?retryWrites=true&w=majority

# Server Port
PORT=3001

# xAI (Grok) API (keep this key on the server only)
# Create a key in the xAI console and set it here.
XAI_API_KEY=
# Optional: override model/base URL
XAI_MODEL=grok-4.20-reasoning
XAI_BASE_URL=https://api.x.ai/v1
